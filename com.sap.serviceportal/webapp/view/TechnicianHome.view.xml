<mvc:View
	controllerName="com.sap.serviceportal.controller.TechnicianHome"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'com/sap/serviceportal/model/formatter'
	}">

	<Page showHeader="false" enableScrolling="true" backgroundDesign="Solid">
		<content>
			<VBox>

				<!-- Top Bar -->
				<Toolbar class="spTopBar">
					<Button icon="sap-icon://menu2" type="Transparent" />
					<Image src="img/sap-logo.svg" class="spSapLogoImg" />
					<Text text="Sales and Service Cloud" class="spAppTitle" />
					<ToolbarSpacer />
					<SearchField width="240px" placeholder="Search" />
					<Button icon="sap-icon://bell" type="Transparent" />
					<Button icon="sap-icon://action-settings" type="Transparent" />
					<Avatar initials="{service>/technicianUser/initials}" backgroundColor="Accent7"
						press=".onAvatarPress" />
				</Toolbar>

				<!-- Hero Banner -->
				<FlexBox direction="Column" class="spHeroBanner">
					<items>
						<Text text="{service>/techWelcomeDate}" class="spHeroDate" />
						<Title text="Good morning, {service>/technicianUser/name}"
							class="spHeroTitle" titleStyle="H3" />
						<Text text="{service>/techWelcomeStats}" class="spHeroStats" />
					</items>
				</FlexBox>

				<VBox class="spContent">

					<!-- My Cards: 3-column grid -->
					<l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="1" vSpacing="1"
						class="sapUiSmallMarginBottom">
						<l:content>

							<!-- Quick Actions -->
							<Panel headerText="Quick Actions" class="spPanel">
								<content>
									<l:Grid defaultSpan="XL4 L4 M4 S4" hSpacing="0.5" vSpacing="0.5"
										class="sapUiSmallMargin">
										<l:content>
											<Button text="View Cases"    icon="sap-icon://task"       type="Transparent" width="100%" class="spQuickActionTile" press=".onViewCases" />
											<Button text="Accept Case"   icon="sap-icon://accept"     type="Transparent" width="100%" class="spQuickActionTile" press=".onViewCases" />
											<Button text="Mark En Route" icon="sap-icon://map"        type="Transparent" width="100%" class="spQuickActionTile" />
											<Button text="Update Status" icon="sap-icon://synchronize" type="Transparent" width="100%" class="spQuickActionTile" />
											<Button text="Request Parts" icon="sap-icon://product"    type="Transparent" width="100%" class="spQuickActionTile" />
											<Button text="My Learning"   icon="sap-icon://e-learning"  type="Transparent" width="100%" class="spQuickActionTile" press=".onLearning" />
										</l:content>
									</l:Grid>
								</content>
							</Panel>

							<!-- My Cases by Stage -->
							<Panel headerText="My Cases by Stage" class="spPanel">
								<content>
									<VBox class="sapUiSmallMarginBeginEnd">
										<core:HTML content="&lt;div style='height:8px'&gt;&lt;/div&gt;" />
										<List items="{service>/casesByStage}" showSeparators="None">
											<CustomListItem>
												<HBox alignItems="Center" class="sapUiTinyMarginTopBottom">
													<items>
														<core:HTML
															content="{= '&lt;div class=\'spStageDot ' + ${service>stageClass} + '\'&gt;&lt;/div&gt;'}" />
														<Text text="{service>stage}" class="spTechStageText" />
														<Text text="{service>count}" class="spTechCountText" />
													</items>
												</HBox>
											</CustomListItem>
										</List>
									</VBox>
								</content>
							</Panel>

							<!-- Today's Performance -->
							<Panel headerText="Today's Performance" class="spPanel">
								<content>
									<VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
										<FlexBox justifyContent="SpaceBetween"
											class="sapUiSmallMarginTopBottom">
											<items>
												<VBox alignItems="Center" class="spPerfKpiCell">
													<Title text="{service>/techPerformance/ticketsResolved}" level="H2" class="spTechKpiGreen" />
													<Text text="Tickets Resolved This Month" class="spTechKpiLabel" wrapping="true" />
												</VBox>
												<VBox alignItems="Center" class="spPerfKpiCell">
													<Title text="{service>/techPerformance/firstVisitFixRate}" level="H2" class="spTechKpiBlue" />
													<Text text="First Visit Fix Rate" class="spTechKpiLabel" />
												</VBox>
												<VBox alignItems="Center" class="spPerfKpiCell">
													<Title text="{service>/techPerformance/slaRisk}" level="H2" class="spTechKpiOrange" />
													<Text text="SLA at Risk Today" class="spTechKpiLabel" />
												</VBox>
												<VBox alignItems="Center" class="spPerfKpiCell">
													<Title text="{service>/techPerformance/customerRating}" level="H2" class="spTechKpiBlue" />
													<Text text="Customer Rating" class="spTechKpiLabel" />
												</VBox>
											</items>
										</FlexBox>
										<Label text="SLA Compliance" design="Bold" class="sapUiTinyMarginBottom" />
										<ProgressIndicator
											percentValue="{service>/techPerformance/slaCompliance}"
											displayValue="{service>/techPerformance/slaCompliance}% on-time this month"
											state="Success" />
										<Text text="Target: 90%" class="spTechTargetLabel" />
									</VBox>
								</content>
							</Panel>

						</l:content>
					</l:Grid>

					<!-- Today's Scheduled Jobs -->
					<Panel class="spPanel">
						<headerToolbar>
							<Toolbar>
								<Title text="Today's Scheduled Jobs" level="H4" />
								<ToolbarSpacer />
								<Button icon="sap-icon://filter" type="Transparent" />
							</Toolbar>
						</headerToolbar>
						<content>
							<Table items="{service>/scheduledJobs}" noDataText="No jobs scheduled" fixedLayout="false">
								<columns>
									<Column><Text text="TIME" /></Column>
									<Column><Text text="CASE ID" /></Column>
									<Column><Text text="CUSTOMER / LOCATION" /></Column>
									<Column><Text text="ISSUE" /></Column>
									<Column><Text text="PRIORITY" /></Column>
									<Column><Text text="STATUS" /></Column>
									<Column><Text text="ACTIONS" /></Column>
								</columns>
								<items>
									<ColumnListItem type="Inactive">
										<cells>
											<Text text="{service>time}" />
											<Text text="{service>caseId}" />
											<Text text="{service>customer}" wrapping="true" />
											<Text text="{service>issue}" wrapping="true" />
											<ObjectStatus text="{service>priority}"
												state="{path: 'service>priorityState'}" />
											<ObjectStatus text="{service>status}"
												state="{service>statusState}" />
											<HBox>
												<items>
													<Button text="Open"
														type="Emphasized"
														press=".onOpenCase" />
													<Button icon="sap-icon://microphone"
														type="Transparent"
														tooltip="AI Voice Assistant"
														press=".onMicCase" />
												</items>
											</HBox>
										</cells>
									</ColumnListItem>
								</items>
							</Table>
						</content>
					</Panel>

				</VBox>
			</VBox>
		</content>
	</Page>

</mvc:View>
