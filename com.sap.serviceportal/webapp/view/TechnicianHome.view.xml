<mvc:View
	controllerName="com.sap.serviceportal.controller.TechnicianHome"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:l="sap.ui.layout"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'com/sap/serviceportal/model/formatter'
	}">

	<Page showHeader="false" enableScrolling="true" backgroundDesign="Solid">
		<content>
			<VBox>

				<!-- Top Bar -->
				<Toolbar class="spTopBar">
					<Button icon="sap-icon://menu2" type="Transparent" />
					<Image src="img/sap-logo.svg" class="spSapLogoImg" />
					<Text text="Sales and Service Cloud" class="spAppTitle" />
					<ToolbarSpacer />
					<SearchField width="380px" placeholder="Search All" showSearchButton="false" />
					<ToolbarSpacer />
					<Button icon="sap-icon://bell" type="Transparent" tooltip="Notifications" />
					<Button icon="sap-icon://collaborate" type="Transparent" tooltip="Chat" />
					<Button icon="sap-icon://action-settings" type="Transparent" tooltip="Settings" />
					<Button icon="sap-icon://headset" type="Transparent" tooltip="Support" />
					<Avatar initials="{service>/technicianUser/initials}" backgroundColor="Accent7" press=".onAvatarPress" />
					<Button icon="sap-icon://grid" type="Transparent" tooltip="Apps" />
				</Toolbar>

				<!-- Hero Banner -->
				<FlexBox direction="Column" class="spHeroBanner">
					<items>
						<Text text="{service>/techWelcomeDate}" class="spHeroDate" />
						<Title text="Good morning, {service>/technicianUser/name}"
							class="spHeroTitle" titleStyle="H3" />
						<Text text="{service>/techWelcomeStats}" class="spHeroStats" />
					</items>
				</FlexBox>

				<VBox class="spContent">

					<!-- My Cards: 3-column grid -->
					<l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="1" vSpacing="1"
						class="sapUiSmallMarginBottom">
						<l:content>

							<!-- Quick Actions -->
							<Panel headerText="Quick Actions" class="spPanel">
								<content>
									<l:Grid defaultSpan="XL4 L4 M4 S4" hSpacing="0.5" vSpacing="0.5"
										class="sapUiSmallMargin">
										<l:content>
											<Button text="View Cases"    icon="sap-icon://task"       type="Transparent" width="100%" class="spQuickActionTile" press=".onViewCases" />
											<Button text="Accept Case"   icon="sap-icon://accept"     type="Transparent" width="100%" class="spQuickActionTile" press=".onViewCases" />
											<Button text="Mark En Route" icon="sap-icon://map"        type="Transparent" width="100%" class="spQuickActionTile" />
											<Button text="Update Status" icon="sap-icon://synchronize" type="Transparent" width="100%" class="spQuickActionTile" />
											<Button text="Request Parts" icon="sap-icon://product"    type="Transparent" width="100%" class="spQuickActionTile" />
											<Button text="My Learning"   icon="sap-icon://e-learning"  type="Transparent" width="100%" class="spQuickActionTile" press=".onLearning" />
										</l:content>
									</l:Grid>
								</content>
							</Panel>

							<!-- My Cases by Priority -->
							<Panel class="spPanel">
								<headerToolbar>
									<Toolbar>
										<Title text="My Cases by Priority" level="H4" />
										<ToolbarSpacer />
										<Button icon="sap-icon://action" type="Transparent" tooltip="Open" />
									</Toolbar>
								</headerToolbar>
								<content>
									<core:HTML content="&lt;div class='spTechDonut'&gt;&lt;svg viewBox='0 0 100 100' class='spTechDonutSvg'&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#f0f0f0' stroke-width='14'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#bb0000' stroke-width='14' stroke-dasharray='43.98 219.9' stroke-dashoffset='0' transform='rotate(-90 50 50)'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#cc6600' stroke-width='14' stroke-dasharray='65.97 219.9' stroke-dashoffset='-43.98' transform='rotate(-90 50 50)'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#107e3e' stroke-width='14' stroke-dasharray='87.96 219.9' stroke-dashoffset='-109.95' transform='rotate(-90 50 50)'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#8a9ab0' stroke-width='14' stroke-dasharray='21.99 219.9' stroke-dashoffset='-197.91' transform='rotate(-90 50 50)'/&gt;&lt;text x='50' y='54' text-anchor='middle' font-size='22' font-weight='700' fill='#1b1f23'&gt;10&lt;/text&gt;&lt;/svg&gt;&lt;div class='spTechDonutLegend'&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#bb0000'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;Immediate&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;2&lt;/span&gt;&lt;/div&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#cc6600'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;Urgent&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;3&lt;/span&gt;&lt;/div&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#107e3e'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;Normal&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;4&lt;/span&gt;&lt;/div&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#8a9ab0'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;Low&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;1&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" />
								</content>
							</Panel>

							<!-- My Cases by Stage -->
							<Panel class="spPanel">
								<headerToolbar>
									<Toolbar>
										<Title text="My Cases by Stage" level="H4" />
										<ToolbarSpacer />
										<Button icon="sap-icon://action" type="Transparent" tooltip="Open" />
									</Toolbar>
								</headerToolbar>
								<content>
									<core:HTML content="&lt;div class='spTechDonut'&gt;&lt;svg viewBox='0 0 100 100' class='spTechDonutSvg'&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#f0f0f0' stroke-width='14'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#0a6ed1' stroke-width='14' stroke-dasharray='43.98 219.9' stroke-dashoffset='0' transform='rotate(-90 50 50)'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#cc6600' stroke-width='14' stroke-dasharray='87.96 219.9' stroke-dashoffset='-43.98' transform='rotate(-90 50 50)'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#8a9ab0' stroke-width='14' stroke-dasharray='21.99 219.9' stroke-dashoffset='-131.94' transform='rotate(-90 50 50)'/&gt;&lt;circle cx='50' cy='50' r='35' fill='none' stroke='#107e3e' stroke-width='14' stroke-dasharray='65.97 219.9' stroke-dashoffset='-153.93' transform='rotate(-90 50 50)'/&gt;&lt;text x='50' y='54' text-anchor='middle' font-size='22' font-weight='700' fill='#1b1f23'&gt;10&lt;/text&gt;&lt;/svg&gt;&lt;div class='spTechDonutLegend'&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#0a6ed1'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;New&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;2&lt;/span&gt;&lt;/div&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#cc6600'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;In Progress&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;4&lt;/span&gt;&lt;/div&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#8a9ab0'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;On Hold&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;1&lt;/span&gt;&lt;/div&gt;&lt;div class='spTechDonutRow'&gt;&lt;span class='spTechDonutSq' style='background:#107e3e'&gt;&lt;/span&gt;&lt;span class='spTechDonutLbl'&gt;Completed&lt;/span&gt;&lt;span class='spTechDonutNum'&gt;3&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" />
								</content>
							</Panel>

						</l:content>
					</l:Grid>

					<!-- Today's Scheduled Jobs -->
					<Panel class="spPanel">
						<headerToolbar>
							<Toolbar>
								<Title text="Today's Scheduled Jobs" level="H4" />
								<ToolbarSpacer />
								<Button icon="sap-icon://filter" type="Transparent" />
							</Toolbar>
						</headerToolbar>
						<content>
							<Table items="{service>/scheduledJobs}" noDataText="No jobs scheduled" fixedLayout="false">
								<columns>
									<Column><Text text="TIME" /></Column>
									<Column><Text text="CASE ID" /></Column>
									<Column><Text text="CUSTOMER / LOCATION" /></Column>
									<Column><Text text="ISSUE" /></Column>
									<Column><Text text="PRIORITY" /></Column>
									<Column><Text text="STATUS" /></Column>
									<Column><Text text="ACTIONS" /></Column>
								</columns>
								<items>
									<ColumnListItem type="Inactive">
										<cells>
											<Text text="{service>time}" />
											<Text text="{service>caseId}" />
											<Text text="{service>customer}" wrapping="true" />
											<Text text="{service>issue}" wrapping="true" />
											<ObjectStatus text="{service>priority}"
												state="{path: 'service>priorityState'}" />
											<ObjectStatus text="{service>status}"
												state="{service>statusState}" />
											<HBox>
												<items>
													<Button text="Open"
														type="Emphasized"
														press=".onOpenCase" />
													<Button icon="sap-icon://microphone"
														type="Transparent"
														tooltip="AI Voice Assistant"
														press=".onMicCase" />
												</items>
											</HBox>
										</cells>
									</ColumnListItem>
								</items>
							</Table>
						</content>
					</Panel>

				</VBox>
			</VBox>
		</content>
	</Page>

</mvc:View>
